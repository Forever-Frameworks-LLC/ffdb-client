{
  "name": "ffdb-client",
  "version": "0.1.2",
  "description": "Framework-agnostic client for FFDB — works in Node.js, browsers, React Native, and Expo",
  "keywords": [
    "database",
    "client",
    "kysely",
    "sqlite",
    "universal",
    "react",
    "react-native",
    "expo"
  ],
  "homepage": "https://github.com/Forever-Frameworks-LLC/ffdb-client#readme",
  "bugs": {
    "url": "https://github.com/Forever-Frameworks-LLC/ffdb-client/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Forever-Frameworks-LLC/ffdb-client.git"
  },
  "license": "UNLICENSED",
  "author": "dev@forever-frameworks.com",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./node": {
      "types": "./dist/src/node/index.d.ts",
      "import": "./dist/src/node/index.js"
    },
    "./react": {
      "types": "./dist/src/react/index.d.ts",
      "import": "./dist/src/react/index.js"
    }
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "directories": {
    "test": "tests"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_LICENSES.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "check": "tsc --noEmit && biome check --write",
    "npm:patch": "npm version patch && npm publish --access public && git push --follow-tags",
    "npm:minor": "npm version minor && npm publish --access public && git push --follow-tags",
    "npm:major": "npm version major && npm publish --access public && git push --follow-tags",
    "npm:publish": "npm publish --access public",
    "test": "vitest run tests/*.test.ts",
    "prepublishOnly": "npm test && npm run build"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.10",
    "@better-auth/passkey": "^1.6.10",
    "@better-auth/stripe": "1.6.10",
    "@better-fetch/fetch": "1.1.21",
    "@better-fetch/logger": "1.1.21",
    "better-auth": "1.6.10",
    "kysely": "0.29.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "25.7.0",
    "@types/react": "19.2.14",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "dotenv": "17.4.2"
  }
}
